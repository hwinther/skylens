# Local web dev config. Copy to `.env.local` (git-ignored) and fill in real values.
# Only EXPO_PUBLIC_* vars reach the client bundle; they are read at bundle time, so
# restart `npm run web` after changing them.

# Backend URL. Leave UNSET to auto-derive http://<metro-host>:5000 — this works for web
# (localhost) AND a physical device (your PC's LAN IP, the same host Metro serves from), with no
# hardcoded IP. Only set it to override, e.g. a different port or a remote backend.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Boot straight into live mode (talks to the backend) instead of the demo replay.
EXPO_PUBLIC_FORCE_LIVE=1

# Observer / hub-subscription centre for live mode (there is no GPS on web). Use your
# real home lat/lon here — this file's copy (.env.local) is git-ignored, so it stays local.
# HOME_ALT is metres above mean sea level; it feeds the AR elevation angle (omit → sea level).
EXPO_PUBLIC_HOME_LAT=
EXPO_PUBLIC_HOME_LON=
EXPO_PUBLIC_HOME_ALT=

# Google Maps Android API key. NOT an EXPO_PUBLIC_ var — app.config.js reads it at build
# time and bakes it into the native Android manifest (never into the JS bundle). Only needed
# for on-device Android builds; web (Leaflet/OSM) and the demo replay don't use it. For EAS
# cloud builds, set the same-named EAS env var instead of relying on this file.
# GOOGLE_MAPS_API_KEY=

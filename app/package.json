{
  "name": "skylens",
  "version": "0.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "reverse:android": "adb reverse tcp:5000 tcp:5000",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:ci": "eslint . --format json",
    "build": "expo export --platform android",
    "build:web": "expo export --platform web",
    "test": "jest",
    "coverage:ci": "jest --coverage",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --config playwright.ci.config.ts",
    "e2e:report": "playwright show-report",
    "openapi:generate": "openapi-typescript ../backend/src/Api/openapi.json -o src/api/generated/schema.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "@expo/vector-icons": "^15.0.2",
    "@microsoft/signalr": "10.0.0",
    "expo": "~57.0.1",
    "expo-auth-session": "~57.0.1",
    "expo-camera": "~57.0.0",
    "expo-crypto": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-sensors": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "leaflet": "^1.9.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.0.2",
    "react-native-maps": "1.29.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "satellite.js": "^7.0.1",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.2.2",
    "eslint": "9.39.3",
    "eslint-config-expo": "~57.0.0",
    "jest": "30.4.2",
    "jest-expo": "~57.0.0",
    "jest-junit": "^17.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.9.2"
  }
}

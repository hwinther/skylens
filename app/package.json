    "expo": "~57.0.1",
    "expo-auth-session": "~57.0.1",
    "expo-camera": "~57.0.0",
    "expo-crypto": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-location": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-sensors": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-maps": "1.27.2",

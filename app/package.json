    "@types/react": "~19.2.2",
    "eslint": "9.39.3",
    "eslint-config-expo": "~57.0.0",
    "jest": "30.2.0",
    "jest-expo": "~57.0.0",
    "jest-junit": "^17.0.0",
    "typescript": "~5.9.2"
